}

.theme-light .section-label {
  color: #8a58ff !important;
  text-shadow: 2rpx 2rpx 10rpx rgba(127, 69, 242, 0.14) !important;
}

.theme-dark .section-label {
  color: #d4ff58 !important;
  text-shadow: 2rpx 2rpx 10rpx rgba(194, 255, 18, 0.14) !important;
}

