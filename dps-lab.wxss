.theme-light {
  --title-shadow-single: 4rpx 4rpx 14rpx rgba(145, 76, 255, 0.16);
  --copy-shadow-single: 2rpx 2rpx 8rpx rgba(127, 69, 242, 0.12);
  --copy-shadow-strong-single: 3rpx 3rpx 10rpx rgba(127, 69, 242, 0.14);
}

.hero-title,
.panel-title,
.chart-title,
.effect-title,
.portrait-stage-title,
.floating-stage-copy,
